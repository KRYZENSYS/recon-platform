{
  "name": "Recon Platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.flake8",
        "ms-toolsai.datawrangler"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    },
    "codespaces": {
      "openFiles": ["README.md"]
    }
  },
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "Recon Platform Web UI",
      "visibility": "public",
      "autoForward": true
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "runServices": [],
  "otherPortsAttributes": {}
}